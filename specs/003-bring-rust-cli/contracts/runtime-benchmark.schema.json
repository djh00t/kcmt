{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/djh00t/kcmt/specs/003-bring-rust-cli/contracts/runtime-benchmark.schema.json",
  "title": "kcmt Runtime Benchmark Report",
  "type": "object",
  "required": [
    "schema_version",
    "timestamp",
    "command_set",
    "corpora",
    "results",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "command_set": {
      "type": "string",
      "minLength": 1
    },
    "corpora": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "scenario_id",
          "workflow_contract_id",
          "corpus_id",
          "runtime",
          "command_label",
          "iterations",
          "status",
          "wall_time_ms"
        ],
        "properties": {
          "scenario_id": {
            "type": "string",
            "minLength": 1
          },
          "workflow_contract_id": {
            "type": "string",
            "minLength": 1
          },
          "corpus_id": {
            "type": "string",
            "minLength": 1
          },
          "runtime": {
            "type": "string",
            "enum": [
              "python",
              "rust"
            ]
          },
          "command_label": {
            "type": "string",
            "minLength": 1
          },
          "iterations": {
            "type": "integer",
            "minimum": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "passed",
              "failed",
              "excluded"
            ]
          },
          "wall_time_ms": {
            "type": "number",
            "minimum": 0
          },
          "median_time_ms": {
            "type": "number",
            "minimum": 0
          },
          "peak_rss_bytes": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "exit_code": {
            "type": [
              "integer",
              "null"
            ]
          },
          "failure_reason": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "status": {
                  "const": "excluded"
                }
              }
            },
            "then": {
              "required": [
                "failure_reason"
              ]
            }
          }
        ],
        "additionalProperties": false
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "python",
        "rust"
      ],
      "properties": {
        "python": {
          "$ref": "#/$defs/runtimeSummary"
        },
        "rust": {
          "$ref": "#/$defs/runtimeSummary"
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "runtimeSummary": {
      "type": "object",
      "required": [
        "scenario_count",
        "passed",
        "failed",
        "excluded",
        "median_wall_time_ms"
      ],
      "properties": {
        "scenario_count": {
          "type": "integer",
          "minimum": 0
        },
        "passed": {
          "type": "integer",
          "minimum": 0
        },
        "failed": {
          "type": "integer",
          "minimum": 0
        },
        "excluded": {
          "type": "integer",
          "minimum": 0
        },
        "median_wall_time_ms": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
